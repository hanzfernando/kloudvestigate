generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  role      Role       @default(OPERATOR)
  createdAt DateTime   @default(now())
  audits    AuditLog[]
}

model Station {
  id           String   @id @default(cuid())
  externalId   String   @unique
  name         String
  stationType  String
  city         String?
  isActive     Boolean  @default(true)
  metadataJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  investigations TelemetryInvestigation[]
  caches         AggregationCache[]
}

model TelemetryInvestigation {
  id             String              @id @default(cuid())
  stationId      String
  metric         String
  startAt        DateTime
  endAt          DateTime
  question       String
  answer         String?
  status         InvestigationStatus @default(COMPLETED)
  contextJson    Json
  prompt         String
  tokenEstimate  Int
  createdById    String?
  createdAt      DateTime            @default(now())

  station Station @relation(fields: [stationId], references: [id])

  @@index([stationId, metric, startAt, endAt])
}

model AggregationCache {
  id              String   @id @default(cuid())
  stationId       String
  metric          String
  startAt         DateTime
  endAt           DateTime
  intervalMinutes Int
  summaryJson     Json
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id])

  @@unique([stationId, metric, startAt, endAt, intervalMinutes])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  action       String
  resourceType String
  resourceId   String?
  metadataJson Json?
  createdAt    DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([action, createdAt])
}

enum Role {
  ADMIN
  ENGINEER
  OPERATOR
  VIEWER
}

enum InvestigationStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}
